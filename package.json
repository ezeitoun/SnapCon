{
  "name": "snapcon",
  "version": "0.0.7",
  "private": true,
  "type": "commonjs",
  "bin": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node22-win-x64,node22-macos-x64,node22-macos-arm64,node22-linux-x64 --out-path dist"
  },
  "dependencies": {
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.21.0"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "parser.js"
    ],
    "targets": [
      "node22-win-x64",
      "node22-macos-x64",
      "node22-macos-arm64",
      "node22-linux-x64"
    ],
    "outputPath": "dist"
  }
}
